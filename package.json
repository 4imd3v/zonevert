{
    "name": "zonevert",
    "version": "0.2.0",
    "description": "A Windows and Linux desktop UI for batch image conversion with FFmpeg.",
    "homepage": "https://zonevert.dev",
    "author": "Zonevert Maintainers <maintainers@zonevert.dev>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/4imd3v/zonevert.git"
    },
    "packageManager": "pnpm@11.5.3",
    "private": true,
    "scripts": {
        "check": "svelte-check --tsconfig ./tsconfig.json && tsx --test tests/*.test.cjs",
        "typecheck": "svelte-check --tsconfig ./tsconfig.json",
        "clean": "node scripts/clean-artifacts.cjs",
        "dev": "vite",
        "predev": "node scripts/fetch-ffmpeg.mjs",
        "build": "vite build",
        "tauri": "tauri",
        "package:linux": "tauri build --bundles deb,appimage",
        "prepackage:linux": "node scripts/fetch-ffmpeg.mjs",
        "package:windows": "tauri build --bundles nsis,msi",
        "prepackage:windows": "node scripts/fetch-ffmpeg.mjs"
    },
    "dependencies": {
        "@tauri-apps/api": "^2.11.1",
        "@tauri-apps/plugin-dialog": "~2.7.1",
        "@tauri-apps/plugin-notification": "~2.3.3"
    },
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tauri-apps/cli": "^2.11.4",
        "@tsconfig/svelte": "^5.0.8",
        "@types/node": "^24.0.0",
        "svelte": "^5.56.4",
        "svelte-check": "^4.7.1",
        "tsx": "^4.22.4",
        "typescript": "^5.7.0",
        "vite": "^8.1.2"
    }
}
